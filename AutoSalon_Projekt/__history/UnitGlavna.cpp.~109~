void __fastcall TFormGlavna::BtnNapredniIzvjestajClick(TObject *Sender)
{
    Memo1->Clear();
    Memo1->Lines->Add("--- FILTRIRANI I SORTIRANI FINANCIJSKI IZVJEŠTAJ ---");
    Memo1->Lines->Add("");

	String sqlUpit =
        "SELECT "
        "  Kupnje.Datum, "
        "  Kupci.Ime || ' ' || Kupci.Prezime AS KupacLookup, "
        "  Automobili.Marka || ' ' || Automobili.Model AS AutoLookup, "
        "  Automobili.Cijena AS Osnovica, "
        "  (Automobili.Cijena * 0.25) AS IzracunatiPDV, "
        "  (Automobili.Cijena * 1.25) AS UkupnoS_PDV "
        "FROM Kupnje "
        "JOIN Kupci ON Kupnje.KupacID = Kupci.ID "
        "JOIN Automobili ON Kupnje.AutomobilID = Automobili.ID "
        "WHERE 1=1";

    String filterPrezime = EditTraziKupca->Text;

    if (filterPrezime != "") {
        sqlUpit += " AND Kupci.Prezime LIKE :filter";
    }

    if (ComboSortIzvjestaj->ItemIndex == 0) {
        sqlUpit += " ORDER BY UkupnoS_PDV ASC";
    } else if (ComboSortIzvjestaj->ItemIndex == 1) {
        sqlUpit += " ORDER BY UkupnoS_PDV DESC";
    }

    try {
        unique_ptr<TFDQuery> query(new TFDQuery(nullptr));
        query->Connection = KonekcijaBaza;
        query->SQL->Text = sqlUpit;

        if (filterPrezime != "") {
            query->ParamByName("filter")->AsString = "%" + filterPrezime + "%";
        }

        query->Open();

        if (query->IsEmpty()) {
            Memo1->Lines->Add("Nema rezultata za unesene kriterije pretrage.");
            return;
        }

        while (!query->Eof) {
            String datum = query->FieldByName("Datum")->AsString;
            String kupac = query->FieldByName("KupacLookup")->AsString;
            String vozilo = query->FieldByName("AutoLookup")->AsString;

            double osnovica = query->FieldByName("Osnovica")->AsFloat;
            double pdv = query->FieldByName("IzracunatiPDV")->AsFloat;
            double ukupno = query->FieldByName("UkupnoS_PDV")->AsFloat;

            Memo1->Lines->Add("Datum transakcije: " + datum);
            Memo1->Lines->Add("Klijent (Lookup): " + kupac);
            Memo1->Lines->Add("Vozilo (Lookup): " + vozilo);
            Memo1->Lines->Add("Osnovica bez poreza: " + FloatToStrF(osnovica, ffNumber, 10, 2) + " EUR");
            Memo1->Lines->Add("PDV 25% (Calculated): " + FloatToStrF(pdv, ffNumber, 10, 2) + " EUR");
            Memo1->Lines->Add("UKUPNO S PDV-om (Calculated): " + FloatToStrF(ukupno, ffNumber, 10, 2) + " EUR");
            Memo1->Lines->Add("---------------------------------------------------------");

