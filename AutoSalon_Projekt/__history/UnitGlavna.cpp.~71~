        } else {
            Memo1->Lines->Add("[JSON]: Nema automobila u bazi, izvoz preskoÞen.");
        }
    } catch (Exception &e) { Memo1->Lines->Add("[JSON GreÜka]: " + e.Message); }

    // =========================================================================
    // 2. XML OPERACIJE (Kupci)
    // =========================================================================
    try {
        std::unique_ptr<TFDQuery> queryKupci(new TFDQuery(nullptr));
        queryKupci->Connection = KonekcijaBaza;
        queryKupci->SQL->Text = "SELECT * FROM Kupci;";
        queryKupci->Open();

        _di_IXMLDocument xmlDoc = NewXMLDocument();
        xmlDoc->Active = true;
        xmlDoc->Options = xmlDoc->Options << doNodeAutoIndent;
        _di_IXMLNode korijen = xmlDoc->AddChild("KatalogKupaca");

        while (!queryKupci->Eof) {
            _di_IXMLNode kupacCvor = korijen->AddChild("Kupac");
            kupacCvor->AddChild("Ime")->Text = queryKupci->FieldByName("Ime")->AsString;
            kupacCvor->AddChild("Prezime")->Text = queryKupci->FieldByName("Prezime")->AsString;
            kupacCvor->AddChild("OIB")->Text = queryKupci->FieldByName("OIB")->AsString;
            kupacCvor->AddChild("ObrisiMe")->Text = "Test";
            queryKupci->Next();
        }

        // SIGURNOSNA PROVJERA: Radimo modifikacije samo ako u bazi ima kupaca!
        if (korijen->ChildNodes->Count > 0) {
            // POPRAVAK ZA PCDATA: Tra×imo prvi stvarni Þvor koji se zove "Kupac"
            _di_IXMLNode prviKupac = korijen->ChildNodes->FindNode("Kupac");

            if (prviKupac != nullptr) {
                // Kada imamo stvarni Þvor, preko FindNode mu mijenjamo tekstualnu vrijednost
                _di_IXMLNode prezimeNode = prviKupac->ChildNodes->FindNode("Prezime");
                if (prezimeNode != nullptr) {
