void __fastcall TFormGlavna::BtnZakljucavanjeClick(TObject *Sender)
{
    Memo1->Lines->Add("Provjeravam dostupnost zadatka...");

    // ZakljuÞavamo provjeru varijable kroz kritiÞnu sekciju da budemo thread-safe
    MojaKriticnaSekcija->Acquire();
    if (ZadatakUProjedu) {
        MojaKriticnaSekcija->Release();
        ShowMessage("Zadatak veµ radi u pozadini! Molimo priÞekajte da zavrÜi.");
        return;
    }

    // Ako je slobodno, podi×emo zastavicu da je zauzeto i otkljuÞavamo sekciju za druge
    ZadatakUProjedu = true;
    MojaKriticnaSekcija->Release();

    Memo1->Lines->Add("Zadatak uspjeÜno pokrenut u pozadini...");

    // Pokreµemo pozadinsku dretvu
    TTask::Run([this]() {
        try {
            Sleep(2000); // Simuliramo rad od 2 sekunde

            // Sinkronizirani i zaÜtiµeni ispis u UI
            MojaKriticnaSekcija->Acquire();
            try {
                TThread::Synchronize(nullptr, [this]() {
                    this->Memo1->Lines->Add("[KritiÞna Sekcija]: Podaci sigurno upisani.");
                });
            }
            __finally {
                MojaKriticnaSekcija->Release();
            }
        }
        __finally {
            // Na samom kraju pozadinskog rada spuÜtamo zastavicu da je slobodno
            TThread::Synchronize(nullptr, [this]() {
                this->ZadatakUProjedu = false;
                this->Memo1->Lines->Add("Pozadinski zadatak zavrÜen. Sustav slobodan.");
            });
        }
    });
}


