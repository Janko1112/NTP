    // 3. DODAVANJE SORTIRANJA
    if (ComboSortIzvjestaj->ItemIndex == 0) {
        sqlUpit += " ORDER BY UkupnoS_PDV ASC";
    } else if (ComboSortIzvjestaj->ItemIndex == 1) {
        sqlUpit += " ORDER BY UkupnoS_PDV DESC";
