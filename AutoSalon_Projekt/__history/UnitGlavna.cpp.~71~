void __fastcall TFormGlavna::BtnPreuzmiKatalogClick(TObject *Sender)
{
    Memo1->Clear();
    Memo1->Lines->Add("--- POKREãEM HTTP PREUZIMANJE PORSCHE KATALOGA ---");
    ProgressBarPreuzimanje->Position = 0;

    System::String url = "https://porsche.com";
    System::String putanjaSpremanja = ExtractFilePath(Application->ExeName) + "Porsche_Katalog_ICE.pdf";

    __int64 bajtovaPoSekundi = 0;
    if (ComboBrzina->ItemIndex == 0) bajtovaPoSekundi = 50 * 1024;   // 50 KB/s
    else if (ComboBrzina->ItemIndex == 1) bajtovaPoSekundi = 200 * 1024; // 200 KB/s
    else bajtovaPoSekundi = 0;

    TTask::Run([this, url, putanjaSpremanja, bajtovaPoSekundi]() {
        try {
            // Kreiramo komponentu pomoµu njezine konkretne Component klase
            std::unique_ptr<TNetHTTPClient> httpKlijent(new TNetHTTPClient(nullptr));

            // HEAD zahtjev za veliÞinu datoteke
            IHTTPResponse* zaglavlje = httpKlijent->Head(url);
            __int64 ukupnoBajtova = zaglavlje->ContentLength;

            if (ukupnoBajtova <= 0) {
                ukupnoBajtova = 500000; // Okvirna procjena ako server ne vrati veliÞinu
            }

            // Clang popravak: Koristimo Þisto suÞelje IHTTPResponse* umjesto klase TIHTTPResponse
            IHTTPResponse* odgovor = httpKlijent->Get(url);
            TStream* mrezniStream = odgovor->ContentStream;

            std::unique_ptr<TFileStream> lokalniFile(new TFileStream(putanjaSpremanja, fmCreate));

            const int velicinaBuffera = 4096;
            std::unique_ptr<char[]> buffer(new char[velicinaBuffera]);

            __int64 ukupnoPreuzeto = 0;
            int procitano = 0;
            unsigned int pocetnoVrijeme = GetTickCount();

            while ((procitano = mrezniStream->Read(buffer.get(), velicinaBuffera)) > 0) {
                lokalniFile->Write(buffer.get(), procitano);
                ukupnoPreuzeto += procitano;

                int postotak = (int)((ukupnoPreuzeto * 100) / ukupnoBajtova);
                if (postotak > 100) postotak = 100;

                TThread::Synchronize(nullptr, [this, postotak]() {
                    this->ProgressBarPreuzimanje->Position = postotak;
                    this->Caption = "Preuzimanje kataloga: " + IntToStr(postotak) + "%";
                });

                if (bajtovaPoSekundi > 0) {
                    unsigned int protekloVrijeme = GetTickCount() - pocetnoVrijeme;
                    if (protekloVrijeme == 0) protekloVrijeme = 1;

                    unsigned int ocekivanoVrijeme = (unsigned int)((ukupnoPreuzeto * 1000) / bajtovaPoSekundi);
                    if (ocekivanoVrijeme > protekloVrijeme) {
                        Sleep(ocekivanoVrijeme - protekloVrijeme);
                    }
                }
            }

            TThread::Synchronize(nullptr, [this, putanjaSpremanja]() {
                this->Caption = "Upravljanje Auto Salonom";
                this->Memo1->Lines->Add("[HTTP]: Preuzimanje uspjeÜno zavrÜeno!");
                this->Memo1->Lines->Add("Datoteka spremljena: " + putanjaSpremanja);
                ShowMessage("Porsche PDF Katalog uspjeÜno preuzet s interneta!");
            });

        } catch (Exception &e) {
            // POPRAVAK ZA LINIJU 1129: IzvlaÞimo tekst poruke van lambde
            System::String tekstGreske = e.Message;
            TThread::Synchronize(nullptr, [this, tekstGreske]() {
                this->Memo1->Lines->Add("[HTTP GreÜka]: " + tekstGreske);
            });
        }
    });
}


