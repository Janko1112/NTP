void __fastcall TFormGlavna::BtnPokreniDllClick(TObject *Sender)
{
    Memo1->Clear();
    Memo1->Lines->Add("Učitavam dinamičku biblioteku 'ProjektKnjiznica.dll'...");

    // 1. Dinamički učitavamo DLL datoteku s diska
    HMODULE hDll = LoadLibrary(L"ProjektKnjiznica.dll");

    if (hDll != NULL) {
        Memo1->Lines->Add("DLL uspješno učitan u memorijski prostor!");

        // Definiramo prototip funkcija koje povlačimo iz DLL-a
        typedef double (__stdcall *PorezFunc)(double);
        typedef double (__stdcall *UvozFunc)(double);

        // 2. Tražimo adrese funkcija unutar učitanog DLL-a (GetProcAddress)
        PorezFunc IzracunajPorez = (PorezFunc)GetProcAddress(hDll, "DllIzracunajPorez");
        UvozFunc IzracunajUvoz = (UvozFunc)GetProcAddress(hDll, "DllIzracunajUvoz");

        if (IzracunajPorez != NULL && IzracunajUvoz != NULL) {

            // 3. Provjeravamo je li korisnik uopće odabrao automobil u izborniku
            if (ComboAutomobili->ItemIndex == -1) {
                ShowMessage("Molimo odaberite automobil iz padajućeg popisa kako bi DLL izračunao troškove!");
                FreeLibrary(hDll);
                return;
            }

            // 4. Izvlačimo ID i naziv odabranog automobila iz teksta (npr. "3 - Audi A4")
            String tekstAuta = ComboAutomobili->Text;
            int autoID = StrToInt(tekstAuta.SubString(1, tekstAuta.Pos(" ") - 1));

            double cijenaIzBaze = 0.0;
            String nazivAuta = "";

            try {
                // 5. Brzim upitom iz baze izvlačimo stvarnu cijenu i model tog auta
                std::unique_ptr<TFDQuery> query(new TFDQuery(nullptr));
                query->Connection = KonekcijaBaza;
                query->SQL->Text = "SELECT Marka, Model, Cijena FROM Automobili WHERE ID = :id;";
                query->ParamByName("id")->AsInteger = autoID;
                query->Open();

                if (!query->IsEmpty()) {
                    nazivAuta = query->FieldByName("Marka")->AsString + " " + query->FieldByName("Model")->AsString;
                    cijenaIzBaze = query->FieldByName("Cijena")->AsFloat;
                } else {
                    ShowMessage("Odabrani automobil više ne postoji u bazi!");
                    FreeLibrary(hDll);
                    return;
                }
            } catch (Exception &e) {
                ShowMessage("Greška pri čitanju auta za DLL: " + e.Message);
                FreeLibrary(hDll);
                return;
            }

            // 6. Prosljeđujemo stvarnu cijenu iz baze u funkcije iz DLL klase!
            double porez = IzracunajPorez(cijenaIzBaze);
            double uvoz = IzracunajUvoz(cijenaIzBaze);

            // Prilagođeni ispis na ekran
            Memo1->Lines->Add("");
            Memo1->Lines->Add("--- REZULTATI IZ VANJSKE DLL KLASE ---");
            Memo1->Lines->Add("Vozilo iz baze: " + nazivAuta + " (ID: " + IntToStr(autoID) + ")");
            Memo1->Lines->Add("Osnovna cijena vozila: " + FloatToStrF(cijenaIzBaze, ffNumber, 10, 2) + " EUR");
            Memo1->Lines->Add("Izračunati PPMV porez (5%): " + FloatToStrF(porez, ffNumber, 10, 2) + " EUR");
            Memo1->Lines->Add("Troškovi uvoza i dostave: " + FloatToStrF(uvoz, ffNumber, 10, 2) + " EUR");
            Memo1->Lines->Add("---------------------------------------");
        } else {
            Memo1->Lines->Add("Greška: Nije moguće dohvatiti adrese funkcija unutar DLL-a.");
        }

        // 7. Oslobađamo knjižnicu iz memorije nakon proračuna
        FreeLibrary(hDll);
        Memo1->Lines->Add("DLL sigurno oslobođen iz memorije.");

    } else {
        ShowMessage("Greška: Datoteka 'ProjektKnjiznica.dll' nije pronađena u mapi programa!");
    }
}



