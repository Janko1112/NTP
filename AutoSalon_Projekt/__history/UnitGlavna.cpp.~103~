void __fastcall TFormGlavna::BtnIzveziSveClick(TObject *Sender)
{
    Memo1->Clear();
    Memo1->Lines->Add("=== DEMONSTRACIJA XML + JSON: PISANJE, UREĐIVANJE, BRISANJE ===");
    Memo1->Lines->Add("");

    // =========================================================================
    // 1. JSON OPERACIJE (Automobili)
    // =========================================================================
    try {
        std::unique_ptr<TJSONArray> katalog(new TJSONArray());
        std::unique_ptr<TFDQuery> query(new TFDQuery(nullptr));
        query->Connection = KonekcijaBaza;
        query->SQL->Text = "SELECT * FROM Automobili;";
        query->Open();

        while (!query->Eof) {
            TJSONObject* autoObj = new TJSONObject();
            autoObj->AddPair("ID", query->FieldByName("ID")->AsString);
            autoObj->AddPair("Marka", query->FieldByName("Marka")->AsString);
            autoObj->AddPair("Model", query->FieldByName("Model")->AsString);
            autoObj->AddPair("Cijena", query->FieldByName("Cijena")->AsFloat);
            autoObj->AddPair("PrivremeniTag", "ZaBrisanje");
            katalog->Add(autoObj);
            query->Next();
        }

        // SIGURNOSNA PROVJERA: Radimo modifikacije samo ako u bazi ima auta!
        if (katalog->Count > 0) {
            TJSONObject* prviAuto = (TJSONObject*)katalog->Get(0);
            if (prviAuto != nullptr) {
                prviAuto->RemovePair("Model");
                prviAuto->AddPair("Model", "MODEL_IZMIJENJEN_U_JSONU");
            }

            for (int i = 0; i < katalog->Count; i++) {
                TJSONObject* obj = (TJSONObject*)katalog->Get(i);
                if (obj != nullptr) {
                    obj->RemovePair("PrivremeniTag");
                }
            }

            String putanjaJson = ExtractFilePath(Application->ExeName) + "katalog.json";
            std::unique_ptr<TStringList> datotekaJson(new TStringList());
            datotekaJson->Add(katalog->ToString());
            datotekaJson->SaveToFile(putanjaJson, TEncoding::UTF8);
            Memo1->Lines->Add("[JSON]: Uspješno demonstrirano Pisanje, Izmjena i Brisanje u 'katalog.json'.");
        } else {
            Memo1->Lines->Add("[JSON]: Nema automobila u bazi, izvoz preskočen.");
        }
    } catch (Exception &e) { Memo1->Lines->Add("[JSON Greška]: " + e.Message); }

    // =========================================================================
    // 2. XML OPERACIJE (Kupci)
    // =========================================================================
    try {
        std::unique_ptr<TFDQuery> queryKupci(new TFDQuery(nullptr));
        queryKupci->Connection = KonekcijaBaza;
        queryKupci->SQL->Text = "SELECT * FROM Kupci;";
        queryKupci->Open();

        _di_IXMLDocument xmlDoc = NewXMLDocument();
        xmlDoc->Active = true;
        xmlDoc->Options = xmlDoc->Options << doNodeAutoIndent;
        _di_IXMLNode korijen = xmlDoc->AddChild("KatalogKupaca");

        while (!queryKupci->Eof) {
            _di_IXMLNode kupacCvor = korijen->AddChild("Kupac");
            kupacCvor->AddChild("Ime")->Text = queryKupci->FieldByName("Ime")->AsString;
            kupacCvor->AddChild("Prezime")->Text = queryKupci->FieldByName("Prezime")->AsString;
            kupacCvor->AddChild("OIB")->Text = queryKupci->FieldByName("OIB")->AsString;
            kupacCvor->AddChild("ObrisiMe")->Text = "Test";
            queryKupci->Next();
        }

        // SIGURNOSNA PROVJERA: Radimo modifikacije samo ako u bazi ima kupaca!
        if (korijen->ChildNodes->Count > 0) {
            // POPRAVAK ZA PCDATA: Tražimo prvi stvarni čvor koji se zove "Kupac"
            _di_IXMLNode prviKupac = korijen->ChildNodes->FindNode("Kupac");

            if (prviKupac != nullptr) {
                // Kada imamo stvarni čvor, preko FindNode mu mijenjamo tekstualnu vrijednost
                _di_IXMLNode prezimeNode = prviKupac->ChildNodes->FindNode("Prezime");
                if (prezimeNode != nullptr) {
                    prezimeNode->Text = "PREZIME_IZMIJENJENO_U_XMLU";
                }
            }

            // Brisanje privremenog čvora - također filtriramo samo stvarne "Kupac" čvorove
            for (int i = 0; i < korijen->ChildNodes->Count; i++) {
                _di_IXMLNode kNode = korijen->ChildNodes->Get(i);
                // Preskačemo nevidljive PCDATA razmake, radimo samo nad "Kupac" čvorovima
                if (kNode != nullptr && kNode->NodeName == "Kupac") {
                    _di_IXMLNode dNode = kNode->ChildNodes->FindNode("ObrisiMe");
                    if (dNode != nullptr) {
                        kNode->ChildNodes->Remove(dNode);
                    }
                }
            }

            String putanjaXml = ExtractFilePath(Application->ExeName) + "kupci.xml";
            xmlDoc->SaveToFile(putanjaXml);
            Memo1->Lines->Add("[XML]: Uspješno demonstrirano Pisanje, Izmjena i Brisanje u 'kupci.xml'.");
        } else {
            Memo1->Lines->Add("[XML]: Nema kupaca u bazi, izvoz preskočen.");
        }

    } catch (Exception &e) { Memo1->Lines->Add("[XML Greška]: " + e.Message); }

    ShowMessage("Proces obrade podataka završen!");
}


